        "jsCode": "const stamp=new Date($json.lockedAt??Date.now()).toISOString().replace(/[:.]/g,'-').slice(0,19);\nreturn [{json:{...$json,spreadsheetTitle:`LOCKED Zoom Giveaway ${stamp} — ${Number($json.eligibleCount)} eligible`}}];"
      },
      "id": "3aa0b567-3156-5b94-ac70-f0393bcb583b",
      "name": "Prepare Spreadsheet Metadata",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        340,
        340
      ]
    },
    {
      "parameters": {
        "authentication": "oAuth2",
        "resource": "spreadsheet",
        "operation": "create",
        "title": "={{$('Prepare Spreadsheet Metadata').first().json.spreadsheetTitle}}",
        "sheetsUi": {
          "sheetValues": [
            {
              "title": "Eligible Entrants",
              "hidden": false
            }
          ]
        },
        "options": {
          "locale": "en_US"
        }
      },
      "id": "e0a5e60e-6ced-57a9-b945-c059279fc585",
      "name": "Create Locked Spreadsheet",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.7,
      "position": [
        600,
        340
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const lock=$('Prepare Spreadsheet Metadata').first().json;\nconst entries=Array.isArray(lock.entries)?lock.entries:[];\nif (!entries.length) throw new Error('The locked snapshot contained no entries.');\nreturn entries.map(e=>({json:{'Draw Number':Number(e.drawNumber),'Original Serial':Number(e.serialNo),'Participant Name':e.fullName,'Masked Email':e.maskedEmail,'Present At Lock':e.presentAt,'Eligibility':'ELIGIBLE — LOCKED'}}));"
      },
      "id": "67696fcd-2c91-51bd-97ec-bacb86329850",
      "name": "Create Eligible Row Items",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        860,
        340
      ]
    },
    {
      "parameters": {
        "authentication": "oAuth2",
        "resource": "sheet",
        "operation": "append",
        "documentId": {
          "__rl": true,
          "value": "={{$('Create Locked Spreadsheet').first().json.spreadsheetId}}",
          "mode": "id"
        },
        "sheetName": {
          "__rl": true,
          "value": "Eligible Entrants",
          "mode": "name"
        },
        "columns": {
          "mappingMode": "autoMapInputData",
          "value": {},
          "matchingColumns": [],
          "schema": [],
          "attemptToConvertTypes": false,
          "convertFieldsToString": false
        },
        "options": {
          "useAppend": true,
          "cellFormat": "RAW"
        }
      },
      "id": "29150043-62e0-5133-a69a-670132ff0995",
      "name": "Append Eligible Rows",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.7,
      "position": [
        1120,
        340
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const lock=$('Prepare Spreadsheet Metadata').first().json;\nconst created=$('Create Locked Spreadsheet').first().json;\nreturn [{json:{lockId:lock.lockId,lockedAt:lock.lockedAt,eligibleCount:Number(lock.eligibleCount),source:lock.source,spreadsheetId:created.spreadsheetId,sheetId:String(created.sheets?.[0]?.properties?.sheetId??0),sheetTitle:created.properties?.title??lock.spreadsheetTitle,sheetUrl:created.spreadsheetUrl??`https://docs.google.com/spreadsheets/d/${created.spreadsheetId}/edit`}}];"
      },
      "id": "0df86165-0971-5f3b-b46e-d23d47b2772e",
      "name": "Collapse Sheet Write Result",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1380,
        340
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{'https://sheets.googleapis.com/v4/spreadsheets/' + encodeURIComponent($json.spreadsheetId) + ':batchUpdate'}}",
        "options": {
          "timeout": 30000,
          "response": {
            "response": {
              "neverError": false,
              "responseFormat": "json"
            }
          }
        },
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "googleSheetsOAuth2Api",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({requests:[{updateSheetProperties:{properties:{sheetId:Number($json.sheetId),gridProperties:{frozenRowCount:1}},fields:'gridProperties.frozenRowCount'}},{repeatCell:{range:{sheetId:Number($json.sheetId),startRowIndex:0,endRowIndex:1},cell:{userEnteredFormat:{textFormat:{bold:true},horizontalAlignment:'CENTER'}},fields:'userEnteredFormat(textFormat,horizontalAlignment)'}},{addProtectedRange:{protectedRange:{range:{sheetId:Number($json.sheetId)},description:'Immutable giveaway snapshot. Only the spreadsheet owner should edit this sheet.',warningOnly:false}}}]}) }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        }
      },
      "id": "4ac0f44c-72d6-5412-bc88-566d0a3ee2f6",
      "name": "Protect & Format Spreadsheet",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
