      "id": "f3ca2bc1-b938-5ae7-ba00-5d22c0006fa0",
      "name": "Read Zoom Webhook Secret",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        -900,
        40
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const crypto=require('crypto');\nconst webhookItem=$('Zoom Events Webhook').first();\nconst req=webhookItem.json;\nconst headers={}; for (const [k,v] of Object.entries(req.headers??{})) headers[String(k).toLowerCase()]=v;\nlet rawBody;\nconst rawBase64=webhookItem.binary?.data?.data;\nif (rawBase64) rawBody=Buffer.from(rawBase64,'base64').toString('utf8');\nelse if (typeof req.body==='string') rawBody=req.body;\nelse rawBody=JSON.stringify(req.body??req);\nlet payload; try { payload=JSON.parse(rawBody); } catch { throw new Error('Zoom webhook body is not valid JSON.'); }\nconst secret=String($json.secret_value??''); if (!secret) throw new Error('Zoom webhook secret has not been saved. Run the setup branch first.');\nif (payload.event==='endpoint.url_validation') {\n const plainToken=payload?.payload?.plainToken; if (!plainToken) throw new Error('Validation payload is missing plainToken.');\n return [{json:{validation:true,processable:false,response:{plainToken,encryptedToken:crypto.createHmac('sha256',secret).update(plainToken).digest('hex')}}}];\n}\nconst timestamp=String(headers['x-zm-request-timestamp']??'');\nconst supplied=String(headers['x-zm-signature']??'');\nif (!timestamp||!supplied) throw new Error('Missing Zoom signature headers.');\nconst age=Math.abs(Math.floor(Date.now()/1000)-Number(timestamp)); if (!Number.isFinite(age)||age>300) throw new Error('Zoom webhook timestamp is outside the five-minute replay window.');\nconst expected=`v0=${crypto.createHmac('sha256',secret).update(`v0:${timestamp}:${rawBody}`).digest('hex')}`;\nconst a=Buffer.from(expected); const b=Buffer.from(supplied); if (a.length!==b.length||!crypto.timingSafeEqual(a,b)) throw new Error('Invalid Zoom webhook signature.');\nconst eventType=String(payload.event??'');\nconst meeting=payload?.payload?.object??{}; const participant=meeting.participant??{};\nconst processable=['meeting.participant_joined','meeting.participant_left'].includes(eventType);\nconst participantUuid=String(participant.participant_uuid??participant.id??participant.user_id??'');\nconst rawTime=participant.join_time??participant.leave_time;\nconst eventTime=rawTime?new Date(rawTime).toISOString():new Date(Number(payload.event_ts??Date.now())).toISOString();\nconst meetingUuid=String(meeting.uuid??''); const meetingId=String(meeting.id??'').replace(/\\s/g,'');\nconst registrantId=String(participant.registrant_id??''); const zoomUserId=String(participant.user_id??participant.id??'');\nconst email=String(participant.email??'').trim().toLowerCase(); const name=String(participant.user_name??participant.name??'Unknown participant').trim();\nconst eventKey=crypto.createHash('sha256').update([eventType,meetingUuid,participantUuid,registrantId,email,eventTime].join('|')).digest('hex');\nreturn [{json:{validation:false,processable,response:{ok:true},eventKey,eventType,meetingId,meetingUuid,participantUuid,registrantId,zoomUserId,email,name,eventTime,rawPayload:payload}}];"
      },
